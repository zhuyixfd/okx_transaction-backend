# Database
STATUS=localhost
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
# 留空时自动切换 SQLite（默认 data/app.db）
MYSQL_DB=
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10
SQLITE_PATH=data/app.db

# OKX 私有接口：API Key/Secret/Passphrase 仅存数据库 okx_api_accounts，由前端「OKX API 帐户」录入。
# 此处仅可选连接参数：
# OKX_FOLLOW_USE_PAPER=false
# OKX_FOLLOW_REST_BASE=https://www.okx.com

